DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# LLM provider
GROQ_API_KEY=""

# Gmail integration (Google OAuth 2.0) — from Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/oauth/gmail/callback"

# App base URL used to build OAuth redirect URIs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used to encrypt stored OAuth tokens (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
INTEGRATION_TOKEN_SECRET=""

# Secret for the cron scheduler endpoint (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=""
